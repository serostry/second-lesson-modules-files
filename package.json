  "version": "1.0.0",
  "description": "In this homework you need to prepare a Node.js project with basic tooling and complete several small file system tasks.",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
